\begin_layout Section*
State Space Modeling ideas
\end_layout

\begin_layout Standard
We have data of 
\begin_inset Formula $\pi_{t}$
\end_inset

,
 
\begin_inset Formula $\mathbb{E}_{t}\pi_{t+1}$
\end_inset

,
 
\begin_inset Formula $x_{t}$
\end_inset

 ,
 
\begin_inset Formula $N_{t}$
\end_inset


\end_layout

\begin_layout Standard
## CES (Benchmark)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\pi_{t} & =\alpha\pi_{t-1}+(1-\alpha)\mathbb{E}_{t}\pi_{t+1}+\kappa x_{t}+e_{t}\\
e_{t} & \sim N\!\left(0,\sigma_{e}^{2}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
or 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\pi_{t} & =\alpha\pi_{t-1}+(1-\alpha)\mathbb{E}_{t}\pi_{t+1}+\kappa x_{t}+e_{t}\\
x_{t} & =\phi_{1}x_{t-1}+\zeta_{t}\\
\begin{bmatrix}e_{t}\\
\zeta_{t}
\end{bmatrix} & \sim N\!\left(0,\begin{bmatrix}\sigma_{e}^{2} & \sigma_{e\zeta}\\
\sigma_{\zeta e} & \sigma_{\zeta}^{2}
\end{bmatrix}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $\Sigma=\begin{bmatrix}\sigma_{e}^{2} & \sigma_{e\zeta} & 0 & 0\\
\sigma_{\zeta e} & \sigma_{\zeta}^{2} & 0 & 0\\
0 & 0 & \sigma_{u}^{2} & 0\\
0 & 0 & 0 & \sigma_{\epsilon}^{2}
\end{bmatrix}$
\end_inset

,
 we can also use 
\begin_inset Formula $\Sigma=\begin{bmatrix}\sigma_{e}^{2} & 0 & 0 & 0\\
0 & \sigma_{\zeta}^{2} & 0 & 0\\
0 & 0 & \sigma_{u}^{2} & 0\\
0 & 0 & 0 & \sigma_{\epsilon}^{2}
\end{bmatrix}$
\end_inset

 
\end_layout

\begin_layout Standard
## HSA (Dynamic effect only)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\pi_{t} & =\alpha\pi_{t-1}+(1-\alpha)\mathbb{E}_{t}\pi_{t+1}+\kappa x_{t}{\color{red}-\theta\hat{N}_{t}}+e_{t}\\
x_{t} & =\phi_{1}x_{t-1}+\zeta_{t}\\
N_{t} & =\hat{N}_{t}+\bar{N}_{t}\\
\hat{N}_{t} & =\rho_{1}\hat{N}_{t-1}+\rho_{2}\hat{N}_{t-2}+u_{t}\\
\bar{N}_{t} & =n+\bar{N}_{t-1}+\epsilon_{t}
\end{align*}

\end_inset


\begin_inset Formula 
\[
\begin{bmatrix}e_{t}\\
\zeta_{t}\\
u_{t}\\
\epsilon_{t}
\end{bmatrix}\sim N\!\left(0,\Sigma\right)
\]

\end_inset


\end_layout

\begin_layout Standard
## HSA (Steady-State effect only)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\pi_{t} & =\alpha\pi_{t-1}+(1-\alpha)\mathbb{E}_{t}\pi_{t+1}+{\color{red}\kappa_{t}}x_{t}+e_{t}\\
x_{t} & =\phi_{1}x_{t-1}+\zeta_{t}\\
N_{t} & =\hat{N}_{t}+\bar{N}_{t}\\
\hat{N}_{t} & =\rho_{1}\hat{N}_{t-1}+\rho_{2}\hat{N}_{t-2}+u_{t}\\
\bar{N}_{t} & =n+\bar{N}_{t-1}+\epsilon_{t}\\
\kappa_{t} & =\kappa_{0}+\delta\bar{N}_{t}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\begin{bmatrix}e_{t}\\
\zeta_{t}\\
u_{t}\\
\epsilon_{t}
\end{bmatrix}\sim N\!\left(0,\Sigma\right)
\]

\end_inset


\end_layout

\begin_layout Standard
## HSA (Both effects)
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\pi_{t} & =\alpha\pi_{t-1}+(1-\alpha)\mathbb{E}_{t}\pi_{t+1}+{\color{red}\kappa_{t}}x_{t}{\color{red}-\theta_{t}\hat{N}_{t}}+e_{t}\\
x_{t} & =\phi_{1}x_{t-1}+\zeta_{t}\\
N_{t} & =\hat{N}_{t}+\bar{N}_{t}\\
\hat{N}_{t} & =\rho_{1}\hat{N}_{t-1}+\rho_{2}\hat{N}_{t-2}+u_{t}\\
\bar{N}_{t} & =n+\bar{N}_{t-1}+\epsilon_{t}\\
\theta_{t} & =\theta_{0}+\gamma\hat{N_{t}}\\
\kappa_{t} & =\kappa_{0}+\delta\bar{N}_{t}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\begin{bmatrix}e_{t}\\
\zeta_{t}\\
u_{t}\\
\epsilon_{t}
\end{bmatrix}\sim N\!\left(0,\Sigma\right)
\]

\end_inset


\end_layout

